# Environment: development | production | test
NODE_ENV=development

# Server Port
PORT=5000

# MongoDB Atlas Connection String
# IMPORTANT: In production, ensure you whitelist Render's IP addresses or use 0.0.0.0/0
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/constituency_db?retryWrites=true&w=majority

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Configuration
# Comma-separated list of allowed frontend domains
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
